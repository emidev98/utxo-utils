{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.23.0",
    "generators": {
      "frankfurter": {
        "generatorName": "typescript-fetch",
        "inputSpec": "docs/openapi/frankfurter.json",
        "output": "src/clients/frankfurter/client",
        "additionalProperties": {
          "supportsES6": true,
          "typescriptThreePlus": true
        }
      }
    }
  }
}
